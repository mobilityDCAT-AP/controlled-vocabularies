<https://w3id.org/mobilitydcat-ap/grammar> a skos:ConceptScheme;
  a owl:Ontology;
  dct:title "Data Grammar"@en;
  dct:description "Deprecated controlled vocabulary for the data grammar of a distribution. The property mobilitydcatap:grammar and this related vocabulary are deprecated in mobilityDCAT-AP v3.0.0."@en;
  dct:creator "Mario Scrocca (Cefriel)"@en, "Peter Lubrich (BASt)"@en;
  dct:publisher "NAPCORE SubWG4.4"@en;
  owl:versionInfo "1.0.0"@en;
  owl:versionIRI <https://w3id.org/mobilitydcat-ap/grammar/1.0.0>;
  owl:deprecated true;
  dct:license <https://creativecommons.org/licenses/by/4.0/>;
  <http://purl.org/ontology/bibo/status> "Published Controlled Vocabulary"@en;
  skos:hasTopConcept <https://w3id.org/mobilitydcat-ap/grammar/xsd>, <https://w3id.org/mobilitydcat-ap/grammar/json-schema>,
    <https://w3id.org/mobilitydcat-ap/grammar/asn.1>, <https://w3id.org/mobilitydcat-ap/grammar/protocol-buffers>,
    <https://w3id.org/mobilitydcat-ap/grammar/other> .

<https://w3id.org/mobilitydcat-ap/grammar/xsd> a skos:Concept;
  skos:prefLabel "XSD"@en;
